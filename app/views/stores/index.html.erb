<% content_for :title, "Milkcrate — Stores" %>

<div class="mb-8">
  <h1 class="text-2xl font-bold mc-text mb-1" style="font-family: ui-sans-serif, system-ui, sans-serif; letter-spacing: 0.05em;">
    Record Stores
  </h1>
  <p class="text-sm mc-dim">Choose a store to start digging.</p>
</div>

<% if @stores.any? %>
  <div class="mc-store-grid mb-12">
    <% @stores.each do |store| %>
      <%= link_to store_path(store), class: "mc-store-card" do %>
        <h2><%= store.name %></h2>
        <p class="mb-2">@<%= store.discogs_username %></p>
        <% if store.synced? %>
          <p><%= store.total_listings&.to_s || "?" %> vinyl listings &middot; last synced <%= time_ago_in_words(store.last_synced_at) %> ago</p>
        <% elsif store.syncing? %>
          <p>Syncing inventory…</p>
        <% else %>
          <p>Not yet synced</p>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="py-16 text-center mc-dim text-sm">
    <p class="text-4xl mb-4">🥛</p>
    <p>No stores yet. Add your first Discogs seller to start digging.</p>
  </div>
<% end %>

<%= link_to "+ Add a store", new_store_path, class: "mc-btn mc-btn-primary" %>
