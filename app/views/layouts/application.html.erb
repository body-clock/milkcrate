<!DOCTYPE html>
<html data-theme="dark" data-controller="theme">
  <head>
    <title><%= content_for(:title) || "Milkcrate" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">

  </head>

  <body class="mc-body min-h-screen">
    <header class="mc-header flex items-center justify-between px-4 py-3 border-b mc-border">
      <%= link_to root_path, class: "mc-wordmark text-xl font-semibold", "aria-label" => "Milkcrate. home" do %>
        Milkcrate.
      <% end %>

      <button data-action="click->theme#toggle" class="mc-nav-link text-sm" title="Toggle light/dark">
        ◑
      </button>
    </header>

    <% if notice %>
      <div class="px-4 py-2 text-sm mc-notice" role="alert">
        <%= notice %>
      </div>
    <% end %>

    <main class="px-4 py-6">
      <%= yield %>
    </main>
  </body>
</html>
